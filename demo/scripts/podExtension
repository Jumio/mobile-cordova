# make all the other frameworks into static frameworks by overriding the static_framework? function to return true
pre_install do |installer|
  installer.pod_targets.each do |pod|
    puts "Overriding the static_framework? method for #{pod.name}"
    def pod.static_framework?;
      true
    end
    def pod.build_type;
      Pod::BuildType.static_library
    end
  end
end

post_install do |installer|
    installer.pods_project.targets.each do |target|
        target.build_configurations.each do |config|
            config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
            config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
    end

    # Add Localization to Resources group
    destinationFolder = './App/Resources'
    localizableName = 'Localizable-Jumio.strings'
    project = installer.aggregate_targets[0].user_project

    FileUtils.mkdir_p destinationFolder

    if Dir.exist?('./Pods/Jumio/Localization')
        FileUtils.cp_r './Pods/Jumio/Localization', destinationFolder
    end

    appGroup = project.groups.find { |group| group.name == 'App' || group.path == 'App' }

    if appGroup
        resourcesGroup = appGroup.children.find { |group| group.name == 'Resources' || group.path == 'Resources' }
    else
        resourcesGroup = project.groups.find { |group| group.name == 'Resources' || group.path == 'Resources' }
    end

    if resourcesGroup.nil?
        resourcesGroup = appGroup ? appGroup.new_group('Resources') : project.new_group('Resources')
    end

    localizableGroup = resourcesGroup.children.find { |group| group.name == localizableName }
    if localizableGroup.nil?
        localizableGroup = resourcesGroup.new_variant_group(localizableName)
    end

    localizationDir = destinationFolder + '/Localization'
    if Dir.exist?(localizationDir)
        Dir.foreach(localizationDir) do |folder|
            if folder.include? ".lproj"
                localizableGroup.new_file('Localization/' + folder + '/Localizable-Jumio.strings')
            end
        end
    end

    project.native_targets.each do |target|
        if target.name == 'App'
            target.add_resources([localizableGroup])
        end
    end

    project.save

    installer.generated_projects.each do |project|
        project.targets.each do |target|
            target.build_configurations.each do |config|
                config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
            end
        end
    end
end